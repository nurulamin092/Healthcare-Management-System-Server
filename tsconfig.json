{
    "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2023",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",
  "types": ["node"]
  },
  "include": ["src", "src/app/modules/specialty/specialty.route.ts"],
  "exclude": ["node_modules", "dist"]

}